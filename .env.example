# Copy to .env for local dev. On Netlify: Site configuration → Environment variables (same keys).

# Backend API (must match deployed backend; include /api)
VITE_API_BASE_URL=https://your-backend.onrender.com/api

# Optional: bare origin for Socket.IO when it differs from stripping /api from VITE_API_BASE_URL
# VITE_API_URL=https://your-backend.onrender.com

# Stripe (publishable key only — never put secret keys in the frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
