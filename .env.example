# Copy to .env for local dev. On Netlify: Site configuration → Environment variables (same keys).

# Backend API (must match deployed backend; include /api)
VITE_API_BASE_URL=https://your-backend.onrender.com/api

# Optional: bare origin for Socket.IO when it differs from stripping /api from VITE_API_BASE_URL
# VITE_API_URL=https://your-backend.onrender.com

# Stripe (publishable key only — never put secret keys in the frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# Public guest routes (/menu, /cart, …) require ?restaurantId= on the URL. The app does not
# infer a venue from localStorage or env — that avoids loading the wrong restaurant’s data.

# ── Troubleshooting: "Unsafe attempt to load URL … from frame with URL chrome-error://chromewebdata/" ──
# That message means the *parent* document is Chrome’s built‑in ERROR page (offline, DNS fail, SSL,
# blocked connection), often inside an embedded preview (Cursor Simple Browser, VS Code Simple Browser).
# Browsers forbid loading a real https:// site from that error context — no backend/CORS change fixes it.
# Fix: close the preview, open Chrome or Edge as a normal window → paste your Netlify URL in the bar.
# If it still fails in a real browser, check Netlify Deploy log (build succeeded?) and try another network.
